<script>
const DATA = __DATA__;
const TYPE_COLOR = {system:'#6ba5ff',verification:'#4fd6a8',issue:'#f5b15c',project:'#b98cff',moc:'#8b93ad'};
const GOLD='#ffd479', STALE='#ff7b91', DIMN='#151924', DIML='rgba(74,84,116,.035)';
const LINKBASE={verify:'#3fbf95',plan:'#a87fe6',link:'#4a5474'};
const tc = t => TYPE_COLOR[t] || '#8b93ad';
const byId = {}; DATA.nodes.forEach(n=>byId[n.id]=n);
function baseColor(n){ if(n.status==='stale') return STALE; if(n.inv&&n.inv.length) return GOLD; return tc(n.type); }

// 3d-force-graph 會把 link.source/target 由 id 字串置換成 node 物件參照(= gdata.nodes 的同一物件)
const gdata = {nodes:DATA.nodes, links:DATA.edges.map(e=>({source:e.source,target:e.target,kind:e.kind}))};
const nodeOf = x => (x && x.id!==undefined) ? x : byId[x];

// ---- 高亮狀態(點選 = 只亮鄰域,其餘暗化)----
const hlN=new Set(), hlL=new Set(); let sel=null;
const types=[...new Set(DATA.nodes.map(n=>n.type))];
const active=new Set(types); let staleOnly=false;
function nvisible(n){ return active.has(n.type) && (!staleOnly || n.status==='stale'); }

function ncolor(n){ if(hlN.size && !hlN.has(n)) return DIMN; if(n===sel) return '#ffffff'; return baseColor(n); }
function lcolor(l){ if(hlL.size && !hlL.has(l)) return DIML; return LINKBASE[l.kind]||'#2d3346'; }
function lwidth(l){ return hlL.has(l)?2:0.35; }
function lparticles(l){ return (hlL.has(l) || (hlL.size===0 && l.kind==='plan'))?2:0; }
function larrow(l){ if(hlL.size) return hlL.has(l)?3.4:0; return 2.2; }

const Graph = ForceGraph3D()(document.getElementById('cy'));

// ★ 力場必須在 graphData 之前設定:warmup 在 graphData 當下就用當時的力場把佈局跑完;
//   若事後才改強斥力,模擬已冷卻、救不回 → 永遠擠成「病毒團」。這圖很密(~11 邊/點),
//   link 吸引力會壓過斥力,故大幅加強斥力 + 拉長連線 + 減弱 link 拉力。
Graph.d3Force('charge').strength(-240);
Graph.d3Force('link').distance(l => l.kind==='plan' ? 90 : 65).strength(0.18);
Graph.d3VelocityDecay(0.3);

Graph
  .graphData(gdata)
  .warmupTicks(70)        // 首次繪製前先跑 70 tick(用上面強斥力)→ 一開圖就是攤開的星座,不靠時機
  .cooldownTicks(160)
  .backgroundColor('rgba(0,0,0,0)')
  .showNavInfo(false)
  .nodeRelSize(4)
  .nodeVal(n=>0.8+Math.pow(Math.min(n.indeg,18),1.15)*0.4)
  .nodeColor(ncolor)
  .nodeOpacity(0.9)
  .nodeResolution(18)
  .nodeLabel(n=>'<div style="font:600 12px Space Grotesk,sans-serif;color:#edeff6;background:rgba(15,18,25,.92);padding:5px 10px;border:1px solid #2a3145;border-radius:8px;box-shadow:0 6px 20px -6px rgba(0,0,0,.7)">'+n.label+'<span style="color:#7c8398;font-weight:400"> · '+n.type+(n.status==='stale'?' · stale':'')+(n.inv&&n.inv.length?' · ★'+n.inv.length:'')+'</span></div>')
  .linkColor(lcolor)
  .linkOpacity(0.2)
  .linkWidth(lwidth)
  .linkDirectionalArrowLength(larrow)
  .linkDirectionalArrowRelPos(1)
  .linkDirectionalParticles(lparticles)
  .linkDirectionalParticleWidth(1.2)
  .linkDirectionalParticleSpeed(0.005)
  .nodeVisibility(nvisible)
  .linkVisibility(l=>nvisible(nodeOf(l.source))&&nvisible(nodeOf(l.target)))
  .onNodeClick(focusNode)
  .onBackgroundClick(clearSel);

// 貼合 top bar 下方的容器尺寸(預設會用整個 window 高度,會被頂欄遮 64px)
function sizeGraph(){ Graph.width(window.innerWidth).height(window.innerHeight-64); }
sizeGraph(); window.addEventListener('resize', sizeGraph);

// ---- 常駐節點標籤:HTML 疊層逐幀同步到節點螢幕座標 ----
// 不依賴 three-spritetext(會逼出全域 THREE,風險高、離線臃腫);改用 graph2ScreenCoords 投影,
// 用 Graph.camera() 既有的 Vector3 做前/後剔除(不需自帶 THREE)。
const labLayer=document.getElementById('labels'), labOf=new Map();
DATA.nodes.forEach(n=>{ const d=document.createElement('div'); d.className='nlab';
  d.textContent=n.label; d.style.fontSize=(11+Math.min(n.indeg,16)*0.25)+'px';  // 樞紐字略大,先被看見
  labLayer.appendChild(d); labOf.set(n,d); });
function syncLabels(){
  requestAnimationFrame(syncLabels);
  const cam=Graph.camera(); if(!cam||!cam.position) return;
  const fwd=cam.position.clone(); cam.getWorldDirection(fwd);           // 相機朝向(Vector3,複用內建 THREE)
  const p=cam.position.clone();
  const camDist=cam.position.length()||1;                              // 相機到圖心(力場置中於原點)的距離 → 淡出基準,與縮放無關
  const W=window.innerWidth, H=window.innerHeight-64;
  DATA.nodes.forEach(n=>{
    const d=labOf.get(n);
    if(!nvisible(n)){ d.style.opacity=0; return; }                     // type chip / 只看 stale 過濾
    p.set(n.x||0,n.y||0,n.z||0);
    const to=p.clone().sub(cam.position);
    if(to.dot(fwd)<=0){ d.style.opacity=0; return; }                   // 在相機背後 → 不畫
    const s=Graph.graph2ScreenCoords(n.x||0,n.y||0,n.z||0);
    if(s.x<-40||s.x>W+40||s.y<-20||s.y>H+20){ d.style.opacity=0; return; }  // 出畫面
    d.style.transform='translate('+(s.x)+'px,'+(s.y-13)+'px) translateX(-50%)';  // 置中、略抬到球頂上方
    const dim = hlN.size && !hlN.has(n);                               // 點選聚焦時,非鄰域更淡
    const far = Math.min(1, (camDist*1.2)/(to.length()||1));           // 相對相機距離淡出(縮放不變)→ 框全圖時仍清楚可見
    d.style.opacity = (dim?0.14:0.62) * (0.5+0.5*far);
  });
}
requestAnimationFrame(syncLabels);

function refresh(){
  Graph.nodeColor(ncolor).linkColor(lcolor).linkWidth(lwidth)
       .linkDirectionalArrowLength(larrow).linkDirectionalParticles(lparticles);
}
function applyVis(){
  Graph.nodeVisibility(nvisible)
       .linkVisibility(l=>nvisible(nodeOf(l.source))&&nvisible(nodeOf(l.target)));
}

// ---- 點選節點:只高亮自己+鄰居+相連邊,飛入聚焦 ----
function focusNode(n){
  hlN.clear(); hlL.clear(); sel=n; hlN.add(n);
  gdata.links.forEach(l=>{
    const s=nodeOf(l.source), t=nodeOf(l.target);
    if(s===n){ hlL.add(l); hlN.add(t); }
    else if(t===n){ hlL.add(l); hlN.add(s); }
  });
  refresh();
  const dist=180, h=Math.hypot(n.x||1,n.y||1,n.z||1)||1, r=1+dist/h;
  Graph.cameraPosition({x:(n.x||0)*r,y:(n.y||0)*r,z:(n.z||0)*r}, n, 1100);
  open(n);
}
function clearSel(){ hlN.clear(); hlL.clear(); sel=null; refresh(); panel.classList.remove('open'); }

// ---- 側欄 ----
const panel=document.getElementById('panel'),ttl=panel.querySelector('.ttl'),
      kicker=panel.querySelector('.kicker'),
      meta=panel.querySelector('.meta'),pbody=document.getElementById('pbody');
function strip(raw){const m=raw.match(/^---\n[\s\S]*?\n---\n?/);return m?raw.slice(m[0].length):raw;}
function wl(html){return html.replace(/\[\[([^\]|#]+)(?:[^\]]*)\]\]/g,(m,t)=>
  '<a class="wl" data-t="'+t.trim()+'">'+t.trim()+'</a>');}
function open(n){
  kicker.textContent=n.rel.replace(/\.md$/,'');
  ttl.textContent=n.label;
  let m='<span class="badge type" style="background:'+tc(n.type)+'">'+n.type+'</span>';
  m+='<span class="badge status">'+(n.status||'—')+'</span>';
  if(n.inv&&n.inv.length)m+='<span class="badge inv">★ '+n.inv.length+' 合約</span>';
  if(n.status==='stale')m+='<span class="badge stale">stale</span>';
  meta.innerHTML=m;
  pbody.innerHTML=wl(marked.parse(strip(n.raw||'')));
  pbody.querySelectorAll('.wl').forEach(a=>a.onclick=()=>{
    const hit=DATA.nodes.find(x=>x.label===a.dataset.t||x.rel.endsWith('/'+a.dataset.t+'.md'));
    if(hit) focusNode(hit);
  });
  pbody.scrollTop=0; panel.classList.add('open');
}
document.getElementById('close').onclick=clearSel;

// ---- 搜尋:命中者高亮,其餘暗化 ----
document.getElementById('search').oninput=e=>{
  const q=e.target.value.trim().toLowerCase();
  hlN.clear(); hlL.clear(); sel=null;
  if(q) DATA.nodes.forEach(n=>{ if(n.label.toLowerCase().includes(q)) hlN.add(n); });
  refresh();
};

// ---- type 過濾 chips ----
const tcw=document.getElementById('typechips');
types.forEach(t=>{
